# Proveedor de IA: "ollama" (local, por defecto) u "opencode" (API remota,
# para despliegues sin Ollama disponible, p.ej. un VPS)
LLM_PROVIDER=ollama

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# OpenCode Go (solo si LLM_PROVIDER=opencode) — https://opencode.ai/docs/go/
OPENCODE_API_KEY=
OPENCODE_MODEL=deepseek-v4-flash

# Seguridad (cambia esto en producción)
JWT_SECRET=cambia-esta-clave-por-una-larga-y-aleatoria

# Filtro de noticias
INTERESTING_THRESHOLD=6

# Ingesta en segundo plano
POLL_MINUTES=20
MAX_ENTRIES_PER_SOURCE=25
ARTICLE_MAX_CHARS=4000

# Base de datos
DATABASE_URL=sqlite:///./fisgon.db
